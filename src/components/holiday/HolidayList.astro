---
import type { ResolvedHoliday } from '@/data/schema';
import HolidayCard from '@/components/holiday/HolidayCard.astro';
import { MONTH_NAMES } from '@/lib/constants';

interface Props {
  holidays: ResolvedHoliday[];
  muted?: boolean;
  title?: string;
}

const { holidays, muted = false, title } = Astro.props;

const grouped = holidays.reduce<Record<number, ResolvedHoliday[]>>((acc, holiday) => {
  const month = holiday.resolvedDate.getMonth();
  if (!acc[month]) acc[month] = [];
  acc[month].push(holiday);
  return acc;
}, {});
---

<section class="space-y-8">
  {title && <h2 class="text-2xl font-semibold text-neutral-900 dark:text-neutral-50">{title}</h2>}
  {
    Object.entries(grouped).map(([monthIndex, monthHolidays]) => (
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-neutral-800 dark:text-neutral-200">
          {MONTH_NAMES[Number(monthIndex)]}
        </h3>
        <div class="grid gap-3">
          {monthHolidays.map((holiday) => (
            <HolidayCard holiday={holiday} muted={muted} />
          ))}
        </div>
      </div>
    ))
  }
</section>
