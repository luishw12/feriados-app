---
import type { HolidayArticle } from '@/data/schema';

interface Props {
  article: HolidayArticle;
}

const { article } = Astro.props;
const sources = article.sources ?? [];
---

{
  sources.length > 0 && (
    <section class="space-y-3 border-t border-neutral-200 pt-8 dark:border-neutral-800">
      <h2 class="text-lg font-semibold text-neutral-900 dark:text-neutral-50">Fontes e referências</h2>
      <ul class="space-y-2">
        {
          sources.map((source) => (
            <li>
              <a
                href={source.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-emerald-700 underline decoration-emerald-300 underline-offset-2 transition-colors duration-150 hover:text-emerald-800 dark:text-emerald-400 dark:decoration-emerald-700 dark:hover:text-emerald-300"
              >
                {source.label}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  )
}
