---
interface Props {
  states: number;
  municipalities: number;
  holidays: number;
  articles: number;
}

const { states, municipalities, holidays, articles } = Astro.props;

const items = [
  { value: states, label: 'estados brasileiros' },
  { value: municipalities, label: 'cidades catalogadas' },
  { value: holidays, label: 'feriados no catálogo' },
  { value: articles, label: 'artigos educativos' },
];
---

<section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-label="Números do projeto">
  {
    items.map((item) => (
      <div class="rounded-xl border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
        <p class="text-2xl font-bold tabular-nums text-emerald-700 dark:text-emerald-400">
          {item.value}
        </p>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">{item.label}</p>
      </div>
    ))
  }
</section>
