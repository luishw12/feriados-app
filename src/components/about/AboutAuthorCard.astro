---
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';
import { AUTHOR_STACK, getAuthorInitials } from '@/lib/about-content';

interface Props {
  authorName: string;
  linkedinUrl: string;
  githubUrl: string;
}

const { authorName, linkedinUrl, githubUrl } = Astro.props;
const initials = getAuthorInitials(authorName);
---

<Card padding="lg" class="space-y-5 border-[#0A66C2]/20 dark:border-[#0A66C2]/30">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start">
    <div
      class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-[#0A66C2] text-xl font-semibold text-white"
      aria-hidden="true"
    >
      {initials}
    </div>
    <div class="space-y-2">
      <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-50">
        Desenvolvido por {authorName}
      </h2>
      <p class="text-neutral-600 dark:text-neutral-400">
        Este projeto foi criado como portfólio técnico, demonstrando Astro com React islands,
        Tailwind CSS e TypeScript. O foco é entregar HTML estático ultra rápido, Core Web Vitals
        sólidos e SEO orgânico — sem backend nem chamadas de API em runtime.
      </p>
    </div>
  </div>

  <ul class="flex flex-wrap gap-2" aria-label="Stack técnica">
    {
      AUTHOR_STACK.map((tech) => (
        <li>
          <span class="inline-flex rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300">
            {tech}
          </span>
        </li>
      ))
    }
  </ul>

  <div class="flex flex-wrap gap-3">
    <a
      href={linkedinUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 rounded-lg bg-[#0A66C2] px-4 py-2 text-sm font-medium text-white transition-colors duration-150 hover:bg-[#004182] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#0A66C2]"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.126 0 2.063 2.063 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
        ></path>
      </svg>
      Conectar no LinkedIn
    </a>
    <Button href={githubUrl} external variant="secondary">Ver no GitHub</Button>
  </div>
</Card>
