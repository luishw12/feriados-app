---
import { ABOUT_FEATURES, type AboutFeatureIcon } from '@/lib/about-content';

const iconPaths: Record<AboutFeatureIcon, string> = {
  calendar:
    'M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z',
  location: 'M12 21s7-4.35 7-11a7 7 0 10-14 0c0 6.65 7 11 7 11z M12 10.5a2.5 2.5 0 110-5 2.5 2.5 0 010 5z',
  layers: 'M12 2 2 7l10 5 10-5-10-5z M2 17l10 5 10-5M2 12l10 5 10-5',
  timer: 'M12 6v6l4 2M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  moon: 'M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z',
  article:
    'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z M14 2v6h6 M16 13H8M16 17H8M10 9H8',
};
---

<section class="space-y-4" aria-labelledby="about-features-heading">
  <h2 id="about-features-heading" class="text-xl font-semibold text-neutral-900 dark:text-neutral-50">
    Funcionalidades
  </h2>
  <ul class="grid gap-4 sm:grid-cols-2">
    {
      ABOUT_FEATURES.map((feature) => (
        <li class="rounded-xl border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
          <div class="flex items-start gap-3">
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300"
              aria-hidden="true"
            >
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={iconPaths[feature.icon]} />
              </svg>
            </div>
            <div class="space-y-1">
              <h3 class="font-semibold text-neutral-900 dark:text-neutral-50">{feature.title}</h3>
              <p class="text-sm text-neutral-600 dark:text-neutral-400">{feature.description}</p>
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</section>
