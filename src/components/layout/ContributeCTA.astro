---
import Card from '@/components/ui/Card.astro';
import Button from '@/components/ui/Button.astro';

const githubUrl = import.meta.env.PUBLIC_GITHUB_URL ?? 'https://github.com/luishw12/feriados-app';
const contributingUrl = `${githubUrl}/blob/main/CONTRIBUTING.md`;
---

<Card id="contribuir" padding="lg" class="space-y-4 border-emerald-200 dark:border-emerald-900/50">
  <div class="flex items-start gap-3">
    <div
      class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300"
      aria-hidden="true"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
        ></path>
      </svg>
    </div>
    <div class="space-y-2">
      <h2 class="text-xl font-semibold text-neutral-900 dark:text-neutral-50">
        Contribua com o projeto
      </h2>
      <p class="text-neutral-600 dark:text-neutral-400">
        Feriados Brasil é open source. Você pode corrigir datas, adicionar feriados municipais,
        melhorar a interface ou a documentação. Toda ajuda é bem-vinda!
      </p>
    </div>
  </div>

  <ul class="list-inside list-disc space-y-1 text-sm text-neutral-600 dark:text-neutral-400">
    <li>
      Dados de feriados em
      <code class="rounded bg-neutral-100 px-1.5 py-0.5 text-xs dark:bg-neutral-800"
        >src/data/holidays/</code
      >
    </li>
    <li>Abra uma issue ou envie um pull request no GitHub</li>
    <li>Cite a fonte oficial ao alterar feriados (lei, decreto ou site do governo)</li>
  </ul>

  <div class="flex flex-wrap gap-3">
    <Button href={githubUrl} external variant="primary">Ver repositório no GitHub</Button>
    <Button href={contributingUrl} external variant="secondary">Guia de contribuição</Button>
  </div>
</Card>
