---
import ThemeToggle from '@/components/interactive/ThemeToggle';
import HolidaySearch from '@/components/interactive/HolidaySearch';

interface Props {
  showLocationSlot?: boolean;
}

const { showLocationSlot = false } = Astro.props;

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const isAbout = pathname.startsWith('/sobre');
const isGuia = pathname.startsWith('/guia');
---

<header class="sticky top-0 z-40 border-b border-neutral-200/80 bg-white/90 px-4 py-3 backdrop-blur-md dark:border-neutral-800/80 dark:bg-neutral-950/90">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-3">
    <a
      href="/"
      class="group flex min-w-0 items-center gap-2.5 rounded-lg outline-none ring-emerald-500 transition-colors duration-150 focus-visible:ring-2"
      aria-label="Feriados Brasil — início"
    >
      <span
        class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-emerald-600 text-white shadow-sm transition-transform duration-150 group-hover:scale-105 dark:bg-emerald-500"
        aria-hidden="true"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
          <circle cx="8" cy="15" r="1" fill="currentColor" stroke="none"></circle>
          <circle cx="12" cy="15" r="1" fill="currentColor" stroke="none"></circle>
          <circle cx="16" cy="15" r="1" fill="currentColor" stroke="none"></circle>
        </svg>
      </span>
      <span class="min-w-0">
        <span class="block truncate text-base font-semibold leading-tight text-neutral-900 dark:text-neutral-50">
          Feriados Brasil
        </span>
        <span class="hidden truncate text-xs text-neutral-500 sm:block dark:text-neutral-400">
          Calendário nacional e regional
        </span>
      </span>
    </a>

    <nav class="flex shrink-0 items-center gap-1.5 sm:gap-2" aria-label="Principal">
      <a
        href="/"
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-150',
          isHome
            ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300'
            : 'text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100',
        ]}
        aria-current={isHome ? 'page' : undefined}
      >
        Calendário
      </a>
      <a
        href="/guia/"
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-150',
          isGuia
            ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300'
            : 'text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100',
        ]}
        aria-current={isGuia ? 'page' : undefined}
      >
        Guias
      </a>
      <a
        href="/sobre/"
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-150',
          isAbout
            ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950/60 dark:text-emerald-300'
            : 'text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-100',
        ]}
        aria-current={isAbout ? 'page' : undefined}
      >
        Sobre
      </a>
      <div class="border-l border-neutral-200 pl-1.5 dark:border-neutral-700 sm:pl-2">
        <HolidaySearch client:idle />
      </div>
      {showLocationSlot && (
        <div
          id="header-location-slot"
          class="min-w-0 border-l border-neutral-200 pl-1.5 dark:border-neutral-700 sm:pl-2"
        />
      )}
      <div class:list={['border-l border-neutral-200 pl-1.5 dark:border-neutral-700 sm:pl-2', !showLocationSlot && 'ml-0.5 sm:ml-1']}>
        <ThemeToggle client:load />
      </div>
    </nav>
  </div>
</header>
