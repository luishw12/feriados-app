---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GuideNav from '@/components/guide/GuideNav.astro';
import FaqSection from '@/components/guide/FaqSection.astro';
import { getGuideHubMeta } from '@/lib/seo';
import { buildGuidePageSchema } from '@/lib/schema';
import { getSiteUrl } from '@/lib/site-url';
import { GUIDE_PAGES } from '@/lib/search-intents';
import { getAllSearchFaqItems } from '@/lib/search-intents';
import { buildNationalYearInsights } from '@/lib/holiday-insights';

const year = new Date().getFullYear();
const meta = getGuideHubMeta(year);
const siteUrl = getSiteUrl(Astro.site);
const insights = buildNationalYearInsights(year);
const faqItems = getAllSearchFaqItems(year, siteUrl).slice(0, 6);
const jsonLd = buildGuidePageSchema(siteUrl, meta.title, `${siteUrl}/guia/`, faqItems, [
  { name: 'Início', url: siteUrl },
  { name: 'Guias', url: `${siteUrl}/guia/` },
]);
---

<BaseLayout title={meta.title} description={meta.description} canonical={meta.canonical} jsonLd={jsonLd}>
  <div class="mx-auto max-w-4xl space-y-10 px-4 py-10">
    <nav class="text-sm text-neutral-500 dark:text-neutral-400" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/" class="hover:text-emerald-600 dark:hover:text-emerald-400">Início</a></li>
        <li aria-hidden="true">/</li>
        <li><span class="text-neutral-700 dark:text-neutral-300">Guias</span></li>
      </ol>
    </nav>

    <section class="space-y-4">
      <h1 class="text-3xl font-semibold text-neutral-900 dark:text-neutral-50">
        Guias de feriados {year}
      </h1>
      <p class="text-neutral-600 dark:text-neutral-400">
        Respostas diretas às buscas mais comuns sobre feriados no Brasil — calendário, dias úteis,
        facultativos, emendas, próximo feriado e datas móveis. Conteúdo estático, ideal para
        mecanismos de busca e assistentes de IA.
      </p>
      <ul class="grid gap-3 sm:grid-cols-2">
        {
          GUIDE_PAGES.map((guide) => (
            <li>
              <a
                href={`/guia/${guide.slug}/`}
                class="block rounded-xl border border-neutral-200 bg-white p-4 transition-colors duration-150 hover:border-emerald-300 dark:border-neutral-800 dark:bg-neutral-900 dark:hover:border-emerald-700"
              >
                <span class="font-semibold text-neutral-900 dark:text-neutral-50">{guide.title} {year}</span>
                <span class="mt-1 block text-sm text-neutral-500 dark:text-neutral-400">
                  {guide.searchTerms.slice(0, 2).join(' · ')}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
        <p class="text-2xl font-bold tabular-nums text-emerald-700 dark:text-emerald-400">{insights.stats.mandatoryTotal}</p>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">feriados nacionais obrigatórios</p>
      </div>
      <div class="rounded-xl border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
        <p class="text-2xl font-bold tabular-nums text-emerald-700 dark:text-emerald-400">{insights.stats.mandatoryWeekdayCount}</p>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">em dias úteis (seg–sex)</p>
      </div>
      <div class="rounded-xl border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
        <p class="text-2xl font-bold tabular-nums text-emerald-700 dark:text-emerald-400">{insights.stats.optionalTotal}</p>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">facultativos federais</p>
      </div>
      <div class="rounded-xl border border-neutral-200 bg-white p-4 dark:border-neutral-800 dark:bg-neutral-900">
        <p class="text-2xl font-bold tabular-nums text-emerald-700 dark:text-emerald-400">{insights.stats.bridgeCount}</p>
        <p class="text-sm text-neutral-600 dark:text-neutral-400">com potencial de emenda</p>
      </div>
    </section>

    <GuideNav currentSlug="hub" />
    <FaqSection items={faqItems} />
  </div>
</BaseLayout>
