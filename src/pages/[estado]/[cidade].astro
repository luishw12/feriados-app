---
import type { GetStaticPaths } from 'astro';
import type { MunicipalityHolidayFile, StateInfo } from '@/data/schema';
import BaseLayout from '@/layouts/BaseLayout.astro';
import HolidayList from '@/components/holiday/HolidayList.astro';
import HolidayMonth from '@/components/holiday/HolidayMonth.astro';
import { getAllMunicipalityPaths, getAllHolidaysForContext } from '@/lib/holidays';
import { getCityMeta } from '@/lib/seo';
import { buildCityPageSchema } from '@/lib/schema';
import { getSiteUrl } from '@/lib/site-url';
import { MONTH_NAMES } from '@/lib/constants';

export const getStaticPaths: GetStaticPaths = () => {
  return getAllMunicipalityPaths().map(({ state, municipality }) => ({
    params: { estado: state.slug, cidade: municipality.slug },
    props: { state, municipality },
  }));
};

interface Props {
  state: StateInfo;
  municipality: MunicipalityHolidayFile;
}

const { state, municipality } = Astro.props;
const year = new Date().getFullYear();
const meta = getCityMeta(
  municipality.name,
  state.name,
  state.uf,
  year,
  state.slug,
  municipality.slug,
);
const holidays = getAllHolidaysForContext(year, state.uf, municipality.slug);
const siteUrl = getSiteUrl(Astro.site);
const jsonLd = buildCityPageSchema(
  holidays,
  municipality.name,
  state.name,
  siteUrl,
  state.slug,
  municipality.slug,
);
---

<BaseLayout title={meta.title} description={meta.description} canonical={meta.canonical} jsonLd={jsonLd}>
  <div class="mx-auto max-w-6xl space-y-10 px-4 py-10">
    <nav class="text-sm text-neutral-500 dark:text-neutral-400" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-2">
        <li>
          <a href="/" class="transition-colors duration-150 hover:text-emerald-600 dark:hover:text-emerald-400">
            Início
          </a>
        </li>
        <li aria-hidden="true">/</li>
        <li>
          <a
            href={`/${state.slug}/`}
            class="transition-colors duration-150 hover:text-emerald-600 dark:hover:text-emerald-400"
          >
            {state.name}
          </a>
        </li>
        <li aria-hidden="true">/</li>
        <li>
          <span class="text-neutral-700 dark:text-neutral-300">{municipality.name}</span>
        </li>
      </ol>
    </nav>

    <section class="space-y-3">
      <h1 class="text-3xl font-semibold text-neutral-900 dark:text-neutral-50">
        Feriados em {municipality.name}/{state.uf} {year}
      </h1>
      <p class="text-neutral-600 dark:text-neutral-400">
        Calendário completo com feriados municipais, estaduais e nacionais de {municipality.name},{' '}
        {state.name}.
      </p>
      <p class="text-sm">
        <a
          href={`/${state.slug}/`}
          class="text-emerald-600 transition-colors duration-150 hover:text-emerald-700 dark:text-emerald-400"
        >
          ← Ver todos os feriados de {state.name}
        </a>
      </p>
    </section>

    <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {
        MONTH_NAMES.map((_, month) => (
          <HolidayMonth holidays={holidays} year={year} month={month} />
        ))
      }
    </section>

    <HolidayList holidays={holidays} title="Todos os feriados" />
  </div>
</BaseLayout>
